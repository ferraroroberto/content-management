        "key": "your_supabase_key_here",
        "enable_upload": true,
        "posts_table": "posts",
        "profile_table": "profile"
    },
    "linkedin_profile": {
        "api_url": "https://fresh-linkedin-profile-data.p.rapidapi.com/get-profile-public-data",
