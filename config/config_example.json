            "title_day": "day",
            "date": "date",
            "wip_checkbox": "work in progress Vd",
            "clip_rel_li": "clip LI(v)",
            "clip_rel_ig": "clip IG(v)",
            "clip_rel_tw": "clip TW(v)",
